{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "venv/bin/uvicorn",
      "runtimeArgs": ["app.main:app", "--host", "0.0.0.0", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "frontend",
      "runtimeExecutable": "venv/bin/streamlit",
      "runtimeArgs": ["run", "frontend/streamlit.py", "--server.address=0.0.0.0", "--server.port=8501"],
      "port": 8501
    }
  ]
}
